FROM python:3.11-slim

WORKDIR /app

COPY pipeline/requirements.txt ./pipeline/
RUN pip install --no-cache-dir -r pipeline/requirements.txt

COPY pipeline/ ./pipeline/

# frontend/public is mounted as a volume at runtime — pipeline writes data.json there
CMD ["sh", "-c", "while true; do python pipeline/fetch_and_analyze.py && echo 'Pipeline complete, sleeping 1h...' && sleep 3600; done"]
